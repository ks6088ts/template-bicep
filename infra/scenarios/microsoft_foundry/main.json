      "type": "string",
      "metadata": {
        "description": "The endpoint of the created Azure AI Foundry account"
      },
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', take(format('{0}-foundry-account-deployment', parameters('name')), 64)), '2025-04-01').outputs.endpoint.value]"
    },
    "foundryProjectId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the created Azure AI Foundry project"
      },
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', take(format('{0}-foundry-project-deployment', parameters('name')), 64)), '2025-04-01').outputs.id.value]"
    },
    "foundryProjectName": {
      "type": "string",
      "metadata": {
        "description": "The name of the created Azure AI Foundry project"
      },
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', take(format('{0}-foundry-project-deployment', parameters('name')), 64)), '2025-04-01').outputs.name.value]"
    },
    "deployedModelNames": {
      "type": "array",
      "metadata": {
        "description": "The names of model deployments requested by this scenario"
      },
      "copy": {
        "count": "[length(parameters('models'))]",
        "input": "[parameters('models')[copyIndex()].name]"
      }
    },
    "roleAssignmentIds": {
      "type": "array",
      "metadata": {
        "description": "The resource IDs of role assignments granted to the existing User Assigned Managed Identity (empty when no UAMI is attached)"
      },
      "copy": {
        "count": "[length(range(0, if(variables('attachExistingUserAssignedIdentity'), length(parameters('roleDefinitionIds')), 0)))]",
        "input": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, variables('resourceGroupName')), 'Microsoft.Resources/deployments', take(format('{0}-role-{1}-deployment', parameters('name'), substring(parameters('roleDefinitionIds')[range(0, if(variables('attachExistingUserAssignedIdentity'), length(parameters('roleDefinitionIds')), 0))[copyIndex()]], 0, 8)), 64)), '2025-04-01').outputs.id.value]"
      }
    }
  }
}