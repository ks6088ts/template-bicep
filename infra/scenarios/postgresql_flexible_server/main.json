              "properties": {
                "workspaceId": "[parameters('workspaceResourceId')]",
                "logs": "[parameters('logs')]",
                "metrics": "[parameters('metrics')]"
              }
            },
            {
              "condition": "[and(variables('isStorage'), contains(parameters('storageServices'), 'file'))]",
              "type": "Microsoft.Insights/diagnosticSettings",
              "apiVersion": "2021-05-01-preview",
              "scope": "[resourceId('Microsoft.Storage/storageAccounts/fileServices', parameters('targetName'), 'default')]",
              "name": "[parameters('name')]",
              "properties": {
                "workspaceId": "[parameters('workspaceResourceId')]",
                "logs": "[parameters('logs')]",
                "metrics": "[parameters('metrics')]"
              }
            }
          ],
          "outputs": {
            "name": {
              "type": "string",
              "metadata": {
                "description": "The name of the diagnostic settings resource."
              },
              "value": "[parameters('name')]"
            }
          }
        }
      },
      "dependsOn": [
        "logAnalyticsWorkspace",
        "postgresServer"
      ]
    }
  },
  "outputs": {
    "resourceGroupId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the created resource group"
      },
      "value": "[reference('resourceGroup').outputs.id.value]"
    },
    "resourceGroupName": {
      "type": "string",
      "metadata": {
        "description": "The name of the created resource group"
      },
      "value": "[reference('resourceGroup').outputs.name.value]"
    },
    "resourceGroupLocation": {
      "type": "string",
      "metadata": {
        "description": "The location of the created resource group"
      },
      "value": "[reference('resourceGroup').outputs.location.value]"
    },
    "postgresServerId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the created PostgreSQL Flexible Server"
      },
      "value": "[reference('postgresServer').outputs.id.value]"
    },
    "postgresServerName": {
      "type": "string",
      "metadata": {
        "description": "The name of the created PostgreSQL Flexible Server"
      },
      "value": "[reference('postgresServer').outputs.name.value]"
    },
    "postgresServerFqdn": {
      "type": "string",
      "metadata": {
        "description": "The fully qualified domain name (FQDN) of the created PostgreSQL Flexible Server"
      },
      "value": "[reference('postgresServer').outputs.fullyQualifiedDomainName.value]"
    },
    "databaseNames": {
      "type": "array",
      "metadata": {
        "description": "The names of databases created on the flexible server"
      },
      "value": "[reference('postgresServer').outputs.databaseNames.value]"
    },
    "logAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": {
        "description": "The resource ID of the created Log Analytics workspace (empty when observability is disabled)"
      },
      "value": "[coalesce(tryGet(if(parameters('enableObservability'), reference('logAnalyticsWorkspace'), null()), 'outputs', 'id', 'value'), '')]"
    }
  }
}